# duprly web app — local env template. Copy to .env and fill in.

# Local dev defaults to SQLite — leave empty to use ./duprly_web.db
# Production (Vercel + Neon): Vercel Marketplace will auto-provision DATABASE_URL / POSTGRES_URL.
# DATABASE_URL=postgresql+psycopg://user:pass@host/db

# Write-auth for JUPR/FUPR POST endpoints. Leave blank locally to allow all writes.
# In production set a strong random value (openssl rand -hex 32).
JUPR_WRITE_API_KEY=

# Live DUPR API credentials — REQUIRED for /dupr/search live fallback and the
# shadow reset simulator. Without these, /api/dupr/search will only return
# players already cached locally, and /api/reset/shadow will refuse to run.
DUPR_USERNAME=
DUPR_PASSWORD=

# Optional: override the FastAPI port when running `uvicorn`.
PORT=8000
